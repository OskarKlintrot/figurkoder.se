@using Figurkoder.Application.Queries;

@page "/game/{gameId}/settings"
@inject IMnemonicQueries MnemonicQueries
@inject NavigationManager NavigationManager

@if (mnemonic is null)
{
    <p>Loading game...</p>
}
else
{
    <CardWithBackground Title="@($"Inställningar för {mnemonic.Title}")" Description=@mnemonic.Description>
        <div class="w-full mt-16 md:mt-0 md:w-2/5 px-auto mx-auto pt-4">
            <EditForm Model="@settings" OnValidSubmit="Play">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <div class="pb-4">
                    @if (mnemonic.Numerical)
                    {
                        <label for="from">Från</label>
                        <InputText type="text" class=@CssInputText @bind-Value="@settings.From" @oninput="OnFromChange" id="from" />

                        <label for="to">Till</label>
                        <InputText type="text" class=@CssInputText @bind-Value="@settings.To" id="to" />
                    }
                    else
                    {
                        <label for="from">Från</label>
                        <InputSelect type="select" class=@CssInputText @bind-Value="@settings.From" @oninput="OnFromChange" id="from">
                            @foreach (var (key, _) in mnemonic.Pairs)
                            {
                                <option value="@key">@key</option>
                            }
                        </InputSelect>

                        <label for="to">Till</label>
                        <InputSelect type="select" class=@CssInputText @bind-Value="@settings.To" id="to">
                            @foreach (var (key, _) in mnemonic.Pairs)
                            {
                                <option value="@key">@key</option>
                            }
                        </InputSelect>
                    }
                </div>

                <div class="flex flex-row">

                    <button class="w-full mx-3 px-3 py-4 font-medium text-white bg-blue-600 rounded-md" type="submit" value="Play">Spela</button>
                    <button class="w-full mx-3 px-3 py-4 font-medium text-white bg-blue-600 rounded-md" type="submit" value="Practice" @onclick="@(()=> settings.Practice = true)">Träna</button>
    
                </div>
            </EditForm>                
        </div>
    </CardWithBackground>
}

@code {
    [Parameter]
    public string GameId { get; set; } = null!;

    private SettingsVM settings = new SettingsVM();

    private Figurkoder.Domain.Mnemonic? mnemonic;
    private string[] mnemonicKeys = Array.Empty<string>();

    private const string CssInputText = 
    @"mt-1
    block
    w-full
    rounded-md
    border-gray-300
    shadow-sm
    focus:border-indigo-300 focus:ring focus:ring-indigo-200 focus:ring-opacity-50";

    protected async override Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (!firstRender)
        {
            return;
        }

        mnemonic = await MnemonicQueries.GetMnemonicAsync(GameId);

        if (mnemonic is null)
        {
            NavigationManager.NavigateTo("/");

            return;
        }

        mnemonicKeys = mnemonic.Pairs.Select(x => x.Key).ToArray();

        settings.From = mnemonic.Pairs[0].Key;
        settings.To = mnemonic.Pairs.Length < 10 ? mnemonic.Pairs[^1].Key : mnemonic.Pairs[9].Key;

        StateHasChanged();
    }

    private void OnFromChange(ChangeEventArgs e)
    {
        var index = Array.IndexOf(mnemonicKeys, e.Value);

        if (index != -1)
        {
            var toIndex = index + 9;

            if (toIndex > mnemonicKeys.Length - 1)
            {
                toIndex = mnemonicKeys.Length - 1;
            }

            settings.To = mnemonicKeys[toIndex];
        }
    }

    private void Play()
    {
        NavigationManager.NavigateTo($"game/{GameId}/play?from={settings.From}&to={settings.To}&practice={settings.Practice}");
    }

    private class SettingsVM
    {
        public string? From { get; set; }
        public string? To { get; set; }
        public bool Practice { get; set; }
    }
}
